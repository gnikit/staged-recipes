{
    "$schema": "https://schemas.conda.org/menuinst-1-1-0.schema.json",
    "menu_name": "Ghostty",
    "menu_items": [
        {
            "name": "Ghostty",
            "description": "A fast, native, feature-rich terminal emulator",
            "command": [
                "{{ PREFIX }}/bin/ghostty",
                "--gtk-single-instance=true"
            ],
            "icon": "{{ MENU_DIR }}/ghostty.{{ ICON_EXT }}",
            "platforms": {
                "linux": {
                    "Categories": [
                        "System",
                        "TerminalEmulator"
                    ],
                    "StartupNotify": true,
                    "DBusActivatable": false
                }
            }
        }
    ]
}
